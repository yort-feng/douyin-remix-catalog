---
import Layout from '../layouts/Layout.astro';
import PosterCard from '../components/PosterCard.astro';
import { ITEMS, PLATFORMS, platformMeta } from '../data/catalog';

// 原始 JSON（含顶层元数据 platform_name / source_keyword / crawled_at 与全部字段），
// 供客户端合并修改后按平台导出，结构与仓库 data/*.json 完全一致。
import iqiyiRaw from '../../../data/iqiyi.json';
import youkuRaw from '../../../data/youku.json';
import mangoRaw from '../../../data/mango.json';
import sohuRaw from '../../../data/sohu.json';

const rawData: Record<string, any> = {
  iqiyi: iqiyiRaw,
  youku: youkuRaw,
  mango: mangoRaw,
  sohu: sohuRaw,
};

const total = ITEMS.length;
const platCount = PLATFORMS.map((p) => ({
  ...p,
  n: ITEMS.filter((i) => i.platform === p.key).length,
}));

// 客户端模糊搜索索引（与首页一致）
const searchIndex = ITEMS.map((i) => ({
  id: i.id,
  title: i.title,
  cast: (i.cast || []).join(' '),
  tags: (i.tags || []).join(' '),
  platformName: platformMeta(i.platform).name,
}));
---

<Layout title="数据校正 · 抖音二创片单" description="手动校正片单数据（片名、集数、演员等），导出修正后的 JSON。">
  <!-- 顶部 -->
  <header class="site-head">
    <div class="wrap head-inner">
      <div class="brand">
        <span class="brand-mark">二创<em>片单</em></span>
        <span class="brand-sub">Edit Mode</span>
      </div>
      <div class="search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <input id="search" type="search" placeholder="搜索要校正的片名 / 演员 / 标签…" autocomplete="off" />
      </div>
      <a class="back-link" href={`${import.meta.env.BASE_URL}`}>← 返回片单</a>
    </div>
  </header>

  <main class="wrap">
    <!-- 主视觉（编辑模式说明） -->
    <section class="hero">
      <span class="hero-eyebrow">数据校正 · Manual Correction</span>
      <h1>
        <span class="cn">修正</span>
        <span class="cn">识别<span class="accent">错误</span></span>
      </h1>
      <p>
        点击任意卡片的「编辑」修改片名、集数、演员等字段。所有修改先保存在本机浏览器（刷新不丢失），
        校正完成后点「导出修正 JSON」下载对应平台文件，替换仓库 <code>data/</code> 目录并提交即可生效。
      </p>

      <div class="hero-stats">
        <div>
          <div class="stat-num">{total}</div>
          <div class="stat-label">部作品</div>
        </div>
        <div>
          <div class="stat-num" id="stat-edited">0</div>
          <div class="stat-label">处本地修改</div>
        </div>
      </div>
    </section>

    <!-- 操作栏 -->
    <div class="edit-actions">
      <button class="btn-primary" id="export-btn" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <path d="M7 10l5 5 5-5"></path>
          <path d="M12 15V3"></path>
        </svg>
        导出修正 JSON
      </button>
      <button class="btn-ghost" id="reset-btn" type="button">清空全部修改</button>
      <span class="edit-hint" id="export-hint">尚无修改</span>
    </div>

    <!-- 筛选栏 -->
    <div class="toolbar">
      <div class="chips" id="chips">
        <button class="chip is-active" data-platform="all" style="--c:var(--accent)">
          <span class="dot"></span>全部平台
        </button>
        {platCount.map((p) => (
          <button class="chip" data-platform={p.key} style={`--c:${p.color}`}>
            <span class="dot"></span>
            {p.name}
            <span style="opacity:.55;font-size:12px">{p.n}</span>
          </button>
        ))}
        <button class="chip chip-edited" data-platform="__edited" style="--c:var(--accent)">
          <span class="dot"></span>仅看已修改
          <span style="opacity:.55;font-size:12px" id="edited-chip-n">0</span>
        </button>
      </div>
      <div class="count">显示 <b id="count">{total}</b> 部</div>
    </div>

    <!-- 卡片网格 -->
    <section class="grid" id="grid">
      {ITEMS.map((item, i) => <PosterCard item={item} index={i} editable />)}
    </section>

    <!-- 空状态 -->
    <div class="empty" id="empty">
      <div class="empty-icon">EMPTY</div>
      <h3>没有匹配的作品</h3>
      <p>换个关键词，或切换平台筛选试试。</p>
    </div>
  </main>

  <!-- 页脚 -->
  <footer class="site-foot">
    <div class="wrap foot-inner">
      <div>
        <div class="foot-brand">二创片单 · Remix Catalog</div>
        <div>数据校正页面 · 修改仅存于本地浏览器，导出后替换 data/*.json 并提交生效。</div>
      </div>
      <div>
        <div style="margin-bottom:8px;color:var(--text-2)">校正提示</div>
        <div>优先修正 OCR 错字与截断片名 · 导出前用「仅看已修改」复核 ·
          <a href="https://github.com/yort-feng/douyin-remix-catalog" target="_blank" rel="noopener">GitHub 仓库 ↗</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- 编辑弹窗 -->
  <div class="modal" id="modal" aria-hidden="true">
    <div class="modal-backdrop" data-close></div>
    <div class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <div class="modal-head">
        <div>
          <div class="modal-eyebrow" id="modal-id">—</div>
          <h2 id="modal-title">编辑作品</h2>
        </div>
        <button class="modal-x" type="button" data-close aria-label="关闭">✕</button>
      </div>

      <div class="modal-body">
        <label class="field">
          <span class="field-label">片名 <em>*</em></span>
          <input id="f-title" type="text" placeholder="如：这是我的西游" />
        </label>

        <div class="field-row">
          <label class="field">
            <span class="field-label">集数</span>
            <input id="f-episodes" type="number" min="0" placeholder="如：76" />
          </label>
          <label class="field">
            <span class="field-label">更新信息</span>
            <input id="f-update" type="text" placeholder="如：共30集/更新至3集" />
          </label>
        </div>

        <div class="field-row">
          <label class="field">
            <span class="field-label">类型 genre</span>
            <input id="f-genre" type="text" placeholder="如：电视剧 / 综艺 / 电影" />
          </label>
          <label class="field">
            <span class="field-label">上映年份</span>
            <input id="f-year" type="number" min="0" placeholder="如：2015" />
          </label>
        </div>

        <label class="field">
          <span class="field-label">标签 tags <i>（用逗号分隔）</i></span>
          <input id="f-tags" type="text" placeholder="如：独播, 热播" />
        </label>

        <label class="field">
          <span class="field-label">主演 cast <i>（用 / 或逗号分隔）</i></span>
          <input id="f-cast" type="text" placeholder="如：孙俪 / 陈建斌 / 蔡少芬" />
        </label>

        <div class="field-row">
          <label class="field">
            <span class="field-label">导演 director</span>
            <input id="f-director" type="text" placeholder="如：郑晓龙" />
          </label>
          <label class="field">
            <span class="field-label">VIP 专属</span>
            <select id="f-vip">
              <option value="">未知</option>
              <option value="1">是（VIP）</option>
              <option value="0">否</option>
            </select>
          </label>
        </div>

        <label class="field">
          <span class="field-label">海报地址 poster_url</span>
          <input id="f-poster" type="text" placeholder="留空则显示片名占位" />
        </label>

        <label class="field">
          <span class="field-label">简介 description</span>
          <textarea id="f-desc" rows="3" placeholder="可选"></textarea>
        </label>

        <div class="modal-readonly">
          <span>热度 heat：<b id="f-heat">—</b></span>
          <span>平台：<b id="f-plat">—</b></span>
        </div>
      </div>

      <div class="modal-foot">
        <button class="btn-ghost btn-danger" id="restore-btn" type="button">恢复原始</button>
        <div class="modal-foot-right">
          <button class="btn-ghost" type="button" data-close>取消</button>
          <button class="btn-primary" id="save-btn" type="button">保存修改</button>
        </div>
      </div>
    </div>
  </div>

  <!-- 数据注入 -->
  <script type="application/json" id="raw-data" set:html={JSON.stringify(rawData)} />
  <script type="application/json" id="catalog-data" set:html={JSON.stringify(searchIndex)} />

  <style>
    .back-link {
      flex-shrink: 0;
      font-size: 13px;
      color: var(--text-2);
      padding: 8px 14px;
      border-radius: 100px;
      border: 1px solid var(--line-strong);
      background: var(--surface);
      transition: color 0.2s, border-color 0.2s;
      white-space: nowrap;
    }
    .back-link:hover {
      color: var(--accent);
      border-color: var(--accent);
    }
    .hero p code {
      font-family: ui-monospace, 'SFMono-Regular', Menlo, monospace;
      font-size: 0.86em;
      padding: 1px 6px;
      border-radius: 5px;
      background: var(--surface-2);
      border: 1px solid var(--line);
      color: var(--accent);
    }

    /* 操作栏 */
    .edit-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin: 6px 0 4px;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      height: 42px;
      padding: 0 20px;
      border-radius: 100px;
      border: 1px solid var(--accent);
      background: var(--accent);
      color: #1a1405;
      font-family: var(--font-ui);
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.18s, box-shadow 0.18s, filter 0.18s;
    }
    .btn-primary svg {
      width: 16px;
      height: 16px;
    }
    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 12px 26px -12px var(--accent-glow);
      filter: brightness(1.05);
    }
    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      height: 42px;
      padding: 0 18px;
      border-radius: 100px;
      border: 1px solid var(--line-strong);
      background: var(--surface);
      color: var(--text-2);
      font-family: var(--font-ui);
      font-size: 13.5px;
      font-weight: 500;
      cursor: pointer;
      transition: color 0.2s, border-color 0.2s;
    }
    .btn-ghost:hover {
      color: var(--text);
      border-color: var(--text-3);
    }
    .btn-ghost.btn-danger:hover {
      color: #ff8a7a;
      border-color: #ff8a7a;
    }
    .edit-hint {
      font-size: 12.5px;
      color: var(--text-3);
    }

    .chip-edited {
      border-style: dashed;
    }

    /* 弹窗 */
    .modal {
      position: fixed;
      inset: 0;
      z-index: 100;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .modal.open {
      display: flex;
    }
    .modal-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(5, 6, 8, 0.72);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }
    .modal-panel {
      position: relative;
      width: min(620px, 100%);
      max-height: 90vh;
      display: flex;
      flex-direction: column;
      border-radius: 18px;
      border: 1px solid var(--line-strong);
      background: var(--bg-2);
      box-shadow: 0 40px 90px -30px rgba(0, 0, 0, 0.9);
      animation: pop 0.28s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes pop {
      from {
        opacity: 0;
        transform: translateY(16px) scale(0.98);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }
    .modal-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      padding: 22px 24px 14px;
      border-bottom: 1px solid var(--line);
    }
    .modal-eyebrow {
      font-size: 11px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 600;
      margin-bottom: 4px;
    }
    .modal-head h2 {
      margin: 0;
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 24px;
      letter-spacing: 0.5px;
      color: var(--text);
    }
    .modal-x {
      flex-shrink: 0;
      width: 34px;
      height: 34px;
      border-radius: 9px;
      border: 1px solid var(--line-strong);
      background: var(--surface);
      color: var(--text-2);
      font-size: 15px;
      cursor: pointer;
      transition: color 0.2s, border-color 0.2s;
    }
    .modal-x:hover {
      color: var(--text);
      border-color: var(--text-3);
    }
    .modal-body {
      padding: 18px 24px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .field {
      display: flex;
      flex-direction: column;
      gap: 6px;
      flex: 1;
    }
    .field-row {
      display: flex;
      gap: 14px;
    }
    .field-label {
      font-size: 12.5px;
      color: var(--text-2);
      font-weight: 500;
    }
    .field-label em {
      color: var(--accent);
      font-style: normal;
    }
    .field-label i {
      font-style: normal;
      color: var(--text-3);
      font-weight: 400;
    }
    .field input,
    .field select,
    .field textarea {
      width: 100%;
      padding: 10px 12px;
      border-radius: 9px;
      border: 1px solid var(--line-strong);
      background: var(--surface);
      color: var(--text);
      font-family: var(--font-ui);
      font-size: 14px;
      transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }
    .field textarea {
      resize: vertical;
      line-height: 1.5;
    }
    .field input:focus,
    .field select:focus,
    .field textarea:focus {
      outline: none;
      border-color: var(--accent);
      background: var(--surface-2);
      box-shadow: 0 0 0 3px var(--accent-soft);
    }
    .modal-readonly {
      display: flex;
      gap: 22px;
      flex-wrap: wrap;
      padding-top: 4px;
      font-size: 12.5px;
      color: var(--text-3);
    }
    .modal-readonly b {
      color: var(--text-2);
      font-weight: 600;
    }
    .modal-foot {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 16px 24px 20px;
      border-top: 1px solid var(--line);
    }
    .modal-foot-right {
      display: flex;
      gap: 10px;
    }
    @media (max-width: 560px) {
      .field-row {
        flex-direction: column;
        gap: 14px;
      }
      .modal-foot {
        flex-direction: column-reverse;
        align-items: stretch;
      }
      .modal-foot-right {
        justify-content: flex-end;
      }
    }
  </style>

  <script>
    import Fuse from 'fuse.js';

    type Edits = Record<string, Record<string, any>>;
    const LS_KEY = 'remix-catalog-edits-v1';

    const rawData = JSON.parse(document.getElementById('raw-data')!.textContent || '{}');
    const searchData = JSON.parse(document.getElementById('catalog-data')!.textContent || '[]');

    // 建立 id -> { platform, item(原始引用) } 索引
    const byId: Record<string, { platform: string; item: any }> = {};
    for (const p of Object.keys(rawData)) {
      const items = rawData[p]?.items || [];
      for (const it of items) byId[it.id] = { platform: p, item: it };
    }

    // 读取本地修改
    let edits: Edits = {};
    try {
      edits = JSON.parse(localStorage.getItem(LS_KEY) || '{}') || {};
    } catch {
      edits = {};
    }
    const persist = () => localStorage.setItem(LS_KEY, JSON.stringify(edits));

    // ---- 网格 / 卡片 ----
    const grid = document.getElementById('grid')!;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.card'));
    const cardById: Record<string, HTMLElement> = {};
    for (const c of cards) cardById[c.dataset.id || ''] = c;

    const empty = document.getElementById('empty')!;
    const countEl = document.getElementById('count')!;
    const searchInput = document.getElementById('search') as HTMLInputElement;
    const chips = Array.from(document.querySelectorAll<HTMLElement>('#chips .chip'));
    const statEdited = document.getElementById('stat-edited')!;
    const editedChipN = document.getElementById('edited-chip-n')!;
    const exportHint = document.getElementById('export-hint')!;

    const fuse = new Fuse(searchData, {
      keys: [
        { name: 'title', weight: 0.4 },
        { name: 'cast', weight: 0.3 },
        { name: 'tags', weight: 0.15 },
        { name: 'platformName', weight: 0.15 },
      ],
      threshold: 0.4,
      ignoreLocation: true,
      minMatchCharLength: 1,
    });

    function isSubseq(q: string, text: string): boolean {
      let i = 0;
      for (const ch of text) {
        if (ch === q[i]) i++;
        if (i === q.length) return true;
      }
      return q.length === 0;
    }

    let activePlatform = 'all';
    let query = '';

    function apply() {
      let matched: Set<string> | null = null;
      if (query) {
        const q = query.toLowerCase();
        matched = new Set(fuse.search(query).map((r) => r.item.id));
        for (const item of searchData) {
          const hit = [item.title, item.cast, item.tags, item.platformName].some(
            (f: string) => f && isSubseq(q, f.toLowerCase()),
          );
          if (hit) matched.add(item.id);
        }
      }
      let visible = 0;
      for (const card of cards) {
        const isEdited = card.classList.contains('is-edited');
        const matchPlat =
          activePlatform === 'all' ||
          (activePlatform === '__edited' ? isEdited : card.dataset.platform === activePlatform);
        const matchQuery = !matched || matched.has(card.dataset.id || '');
        const show = matchPlat && matchQuery;
        card.classList.toggle('is-hidden', !show);
        if (show) visible++;
      }
      countEl.textContent = String(visible);
      empty.classList.toggle('show', visible === 0);
    }

    searchInput.addEventListener('input', () => {
      query = searchInput.value.trim();
      apply();
    });
    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => c.classList.remove('is-active'));
        chip.classList.add('is-active');
        activePlatform = chip.dataset.platform || 'all';
        apply();
      });
    });

    // ---- 修改标记 / 计数 ----
    function refreshEditedUI() {
      const n = Object.keys(edits).length;
      statEdited.textContent = String(n);
      editedChipN.textContent = String(n);
      exportHint.textContent = n === 0 ? '尚无修改' : `已修改 ${n} 处，可导出`;
      for (const c of cards) {
        c.classList.toggle('is-edited', !!edits[c.dataset.id || '']);
      }
    }

    // 把某条修改实时反映到卡片标题
    function refreshCardTitle(id: string) {
      const card = cardById[id];
      if (!card) return;
      const titleEl = card.querySelector<HTMLElement>('.meta-title');
      const eff = effective(id);
      if (titleEl && eff) titleEl.textContent = eff.title;
    }

    function effective(id: string): any {
      const rec = byId[id];
      if (!rec) return null;
      return { ...rec.item, ...(edits[id] || {}) };
    }

    // ---- 弹窗 ----
    const modal = document.getElementById('modal')!;
    const modalId = document.getElementById('modal-id')!;
    const modalTitle = document.getElementById('modal-title')!;
    const fTitle = document.getElementById('f-title') as HTMLInputElement;
    const fEpisodes = document.getElementById('f-episodes') as HTMLInputElement;
    const fUpdate = document.getElementById('f-update') as HTMLInputElement;
    const fGenre = document.getElementById('f-genre') as HTMLInputElement;
    const fYear = document.getElementById('f-year') as HTMLInputElement;
    const fTags = document.getElementById('f-tags') as HTMLInputElement;
    const fCast = document.getElementById('f-cast') as HTMLInputElement;
    const fDirector = document.getElementById('f-director') as HTMLInputElement;
    const fVip = document.getElementById('f-vip') as HTMLSelectElement;
    const fPoster = document.getElementById('f-poster') as HTMLInputElement;
    const fDesc = document.getElementById('f-desc') as HTMLTextAreaElement;
    const fHeat = document.getElementById('f-heat')!;
    const fPlat = document.getElementById('f-plat')!;

    const platName = (p: string) =>
      ({ iqiyi: '爱奇艺', youku: '优酷', mango: '芒果TV', sohu: '搜狐视频' }[p] || p);

    let currentId: string | null = null;

    function openModal(id: string) {
      const rec = byId[id];
      if (!rec) return;
      currentId = id;
      const eff = { ...rec.item, ...(edits[id] || {}) };
      modalId.textContent = `${id} · ${platName(rec.platform)}`;
      modalTitle.textContent = eff.title || '（无片名）';
      fTitle.value = eff.title ?? '';
      fEpisodes.value = eff.episodes ?? '';
      fUpdate.value = eff.update_info ?? '';
      fGenre.value = eff.genre ?? '';
      fYear.value = eff.release_year ?? '';
      fTags.value = (eff.tags || []).join(', ');
      fCast.value = (eff.cast || []).join(' / ');
      fDirector.value = eff.director ?? '';
      fVip.value = eff.vip_required === true ? '1' : eff.vip_required === false ? '0' : '';
      fPoster.value = eff.poster_url ?? '';
      fDesc.value = eff.description ?? '';
      fHeat.textContent = eff.heat ?? '—';
      fPlat.textContent = platName(rec.platform);
      modal.classList.add('open');
      modal.setAttribute('aria-hidden', 'false');
      setTimeout(() => fTitle.focus(), 60);
    }

    function closeModal() {
      modal.classList.remove('open');
      modal.setAttribute('aria-hidden', 'true');
      currentId = null;
    }

    modal.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).hasAttribute('data-close')) closeModal();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });

    // 点卡片任意处打开编辑
    grid.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement).closest<HTMLElement>('.card');
      if (card && card.dataset.id) openModal(card.dataset.id);
    });

    // ---- 解析 / 比较 ----
    const splitList = (s: string, seps: RegExp) =>
      s.split(seps).map((x) => x.trim()).filter(Boolean);
    const numOrNull = (s: string): number | null => {
      const t = s.trim();
      if (t === '') return null;
      const n = Number(t);
      return Number.isFinite(n) ? n : null;
    };
    const eqArr = (a: any, b: any) => JSON.stringify(a || []) === JSON.stringify(b || []);

    function buildDiff(id: string): Record<string, any> {
      const orig = byId[id].item;
      const diff: Record<string, any> = {};

      const title = fTitle.value.trim();
      if (title !== (orig.title ?? '')) diff.title = title;

      const ep = numOrNull(fEpisodes.value);
      if (ep !== (orig.episodes ?? null)) diff.episodes = ep;

      const upd = fUpdate.value.trim();
      if (upd !== (orig.update_info ?? '')) diff.update_info = upd === '' ? null : upd;

      const genre = fGenre.value.trim();
      if (genre !== (orig.genre ?? '')) diff.genre = genre === '' ? null : genre;

      const year = numOrNull(fYear.value);
      if (year !== (orig.release_year ?? null)) diff.release_year = year;

      const tags = splitList(fTags.value, /[,，、\s]+/);
      if (!eqArr(tags, orig.tags)) diff.tags = tags;

      const cast = splitList(fCast.value, /[/／,，、]+|\s+/);
      const origCast = orig.cast || [];
      if (!eqArr(cast, origCast)) diff.cast = cast.length ? cast : null;

      const dir = fDirector.value.trim();
      if (dir !== (orig.director ?? '')) diff.director = dir === '' ? null : dir;

      const vip = fVip.value === '' ? null : fVip.value === '1';
      if (vip !== (orig.vip_required ?? null)) diff.vip_required = vip;

      const poster = fPoster.value.trim();
      if (poster !== (orig.poster_url ?? '')) diff.poster_url = poster === '' ? null : poster;

      const desc = fDesc.value.trim();
      if (desc !== (orig.description ?? '')) diff.description = desc === '' ? null : desc;

      return diff;
    }

    document.getElementById('save-btn')!.addEventListener('click', () => {
      if (!currentId) return;
      if (!fTitle.value.trim()) {
        fTitle.focus();
        fTitle.style.borderColor = '#ff8a7a';
        return;
      }
      const diff = buildDiff(currentId);
      if (Object.keys(diff).length === 0) delete edits[currentId];
      else edits[currentId] = diff;
      persist();
      refreshEditedUI();
      refreshCardTitle(currentId);
      apply();
      closeModal();
    });

    document.getElementById('restore-btn')!.addEventListener('click', () => {
      if (!currentId) return;
      delete edits[currentId];
      persist();
      refreshEditedUI();
      refreshCardTitle(currentId);
      apply();
      closeModal();
    });

    document.getElementById('reset-btn')!.addEventListener('click', () => {
      const n = Object.keys(edits).length;
      if (n === 0) return;
      if (!confirm(`确定清空全部 ${n} 处本地修改？此操作不可撤销。`)) return;
      const ids = Object.keys(edits);
      edits = {};
      persist();
      refreshEditedUI();
      for (const id of ids) refreshCardTitle(id);
      apply();
    });

    // ---- 导出 ----
    function download(filename: string, text: string) {
      const blob = new Blob([text], { type: 'application/json;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    }

    document.getElementById('export-btn')!.addEventListener('click', () => {
      const changedPlats: string[] = [];
      for (const p of Object.keys(rawData)) {
        const items = rawData[p]?.items || [];
        const has = items.some((it: any) => edits[it.id]);
        if (has) changedPlats.push(p);
      }
      if (changedPlats.length === 0) {
        alert('还没有任何修改可导出。');
        return;
      }
      changedPlats.forEach((p, i) => {
        const obj = JSON.parse(JSON.stringify(rawData[p])); // deep clone，保留顶层元数据与字段顺序
        let n = 0;
        for (const it of obj.items) {
          if (edits[it.id]) {
            Object.assign(it, edits[it.id]);
            n++;
          }
        }
        setTimeout(() => download(`${p}.json`, JSON.stringify(obj, null, 2) + '\n'), i * 350);
      });
      exportHint.textContent = `已导出 ${changedPlats.join(' / ')}（共 ${changedPlats.length} 个文件）`;
    });

    // 初始化
    refreshEditedUI();
    apply();
  </script>
</Layout>
