---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '抖音二创片单 · 可二创影视剧查询',
  description = '聚合爱奇艺、优酷、芒果TV、搜狐视频的抖音官方二创片单，快速查询哪些影视剧可以进行二次创作。',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
